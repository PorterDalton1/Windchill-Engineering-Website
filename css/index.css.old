#first_content, #second_content, third_content, h3#third_content_h3, h2#third_content_h3 {
    position: relative;
    z-index: 1;
}

.heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.heading .content_heading {
    height: 550px;
    flex: 45;
}

.heading .content_heading video, .heading .content_heading img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
}

.heading > div:not(.content_heading) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 55;
    padding: 1em;
}

/*
.main_heading {
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-content: center;
    max-width: 60ch;
    flex-shrink: 1;
    height: 100%;
    gap: 1em;
}
*/
.text_heading h2 {
    margin: 0;
    padding: 0;
    margin-block-start: 0;
    margin-block-end: 0;
    font-weight: 400;
    font-size: 2.5em;
    text-transform: uppercase;
}

.text_heading h2 span {
    font-weight: 600;
    color: var(--windchill-blue);
}

.text_heading p {
    margin-top: .5em;
    margin-bottom: .5em;
    font-size: 1.3em;
    max-width: 40ch;
    font-weight: 600;
    line-height: 1.5;
}

.button_flex {
    display: flex;
    justify-content: space-between;
    max-width: 30em;
    width: 100%;
    font-family: "Sansation", sans-serif;
}

.button_flex button {
    font-size: 1em;
    font-weight: 400;
    background: none;
    border: none;
    outline: none;
    padding: .7em;
}

#contact_button {
    background-color: var(--windchill-blue);
    color: white;
}

#learn_button {
    outline: 1px solid var(--windchill-blue);
    color: var(--windchill-blue);
}


#second_content {
    position: relative;
    background-color: lightgrey;
    overflow: hidden;
}

#second_content h2 {
    color: var(--windchill-blue);
    padding-top: 50px;
    font-size: 2.2em;
    width: 100%;
    text-align: center;
    text-transform: uppercase;
    margin: 0;
}

#second_content h3 {
    width: 100%;
    text-align: center;
    margin: 0;
}

@keyframes slide {
  from { left: 0; }
  to {
    left: 100%;
    transform: translateX(-125%);
  }
}

#spacing_client_list {
    height: 300px;;
} 

#client_list {
    position: absolute;
    left:0;
    animation: 60s linear 0s slide infinite;
    display: flex;
    gap: 1.2%;
    width: min-content;
}

#client_list > * {
    align-self: center;
    flex-shrink: 0;
    flex-grow: 0;
}

#text_content {
    padding-top: 100px;
    padding-bottom: 100px;
    padding-left: 10%;
    width: 80%;
    padding-right: 10%;
    background-color: rgb(107, 107, 107);
    color: white;
    font-family: "Sansation", sans-serif;
}

#text_content h3 {
    text-transform: uppercase;
    margin-block-start: 0;
    margin-block-end: 0;
    margin: none;
    padding: none;
}
#text_content h2 {
    margin-block-start: 0;
    margin-block-end: 0;
    margin: none;
    padding: none;
    color:var(--windchill-blue-light);
    font-size: 2em;
}

#text_content p {
    line-height: 1.5;
    font-size: 1.1em;
}

#sub_content_flex {
    padding-top: 50px;
    display: flex;
    padding-bottom: 50px;
    gap: 50px;
}

h3.advantage {
    text-align: center;
}

h2.advantage {
    text-align: center;
}


#icon_content_flex {
    display: flex;
    flex-wrap: wrap;
    row-gap: 80px;
    justify-content: space-between;
    margin-top: 75px;
}

#icon_content_flex > div {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 250px;
    text-align: center;
}

#icon_content_flex img {
    width: 80px;
    background-color: var(--windchill-blue-light);
    color: white;
    padding: 30px;
    border-radius: 20px;
}

#icon_content_flex p {
    margin-top: 0;
    margin-bottom: 0;
}

#icon_content_flex h4 {
    color: var(--windchill-blue-light);
    font-size: 1.5em;
    margin: 0;
    margin-top: 50px;
    text-transform: uppercase;
}

#third_content_background {
    position: absolute;
    z-index: -1;
}

#third_content_background2 {
    position: absolute;
    rotate: 180deg;
    bottom: 0;
    right: 0;
    z-index: -1;
}

h3#third_content_h3 {
    padding-top: 100px;
    font-family: "Sansation", sans-serif;
    text-align: left;
    margin-block-start: 0;
    margin-block-end: 0;
    margin: none;
    padding: none;
    padding-left: 10%;
    color: black;
}

h2#third_content_h2 {
    text-align: left;
    font-family: "Sansation", sans-serif;
    margin-block-start: 0;
    margin-block-end: 0;
    margin: none;
    padding: none;
    padding-left: 10%;
    font-size: 2em;
    color: var(--windchill-blue);
}


#third_content {
    position: relative;
}

#third_content_background.image_crop_box img, #third_content_background2.image_crop_box img {
    object-position: left ;

}

#third_cards_flex {
    display: flex;
    justify-content: space-between;
    row-gap: 40px;
    width: 80%;
    margin-left: 10%;
    flex-wrap: wrap;
    margin-top: 50px;
    padding-bottom: 170px;
}


#third_content .card {
    font-family: "Sansation", sans-serif;
    width: 350px;
    min-height: 450px;
    height: auto;
    border: 2px solid lightgray;
    background-color: lightgray;
    cursor: pointer;
    transform: scale(1);
    transition: transform 0.5s ease;
}

#third_content .card:hover {
    transform: scale(1.08);
}

#third_content .card .image_crop_box {
    width: 100%;
    height: 248px;
    overflow: hidden;
    position: relative;
    background-color: white;
    object-fit: cover;
    outline: 1px solid lightgray;
}

.image_crop_box img {
    width: 100%;
    height: 248px;
    object-fit: cover;
    object-position: center;
    display: block;
}

#third_content .card h3 {
    font-size: 1.15em;
    font-weight: 800;
    color: var(--windchill-blue);
    text-transform: uppercase;
    padding: .5em;
    margin-top: 0;
    margin-bottom: 0;
}

#third_content .card p {
    font-size: 1em;
    padding: .5em;
    line-height: 1.5;
}

#fourth_content {
    padding-top: 200px;
    width: 80%;
    padding-left: 10%;
    padding-right: 10%;
    height: 700px;
    background-color: #585858;
    color: white;
    font-family: "Sansation", sans-serif;
}

#fourth_content #cards_flex {
    display: flex;
    justify-content: space-between;
    width: 100%;
}

#fourth_content .product_card {
    width: 250px;
}

#fourth_content .image_crop_box {
    width: 100%;
    height: 50%;
}

@media (max-width: 1600px) {
    #third_cards_flex {
        justify-content: space-evenly;
    }

}

@media (max-width: 1100px) {

    .heading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2em;
    }

    .heading > div:not(.content_heading) {
        order: 1;
    }

    .heading .content_heading {
        order: 2;
    }

    .heading > .content_heading {
        width: 90%;
        height: 60%;
    }
}

@media (max-width: 650px) {
    .heading .button_flex {
        flex-direction: column;
        gap: 1.5em;
        width: 100%;
    }

    #icon_content_flex {
        justify-content: center;
        width: 100%;
    }

    #second_content img {
        transform: scale(0.75);
    }

    #spacing_client_list {
        height: 250px;;
    }

    #client_list {
        gap: .1%;
        animation: 80s linear 0s slide infinite;
    }
}